digraph api_contracts {
  graph [rankdir=TB, label="api-contracts", labelloc=t]; node [shape=box, style="rounded"];
  args [label="std env args"]; crawl [label="crawl or dungeon"]; update [label="update"]; help [label="help or version"]; repl [label="REPL startup"]; parse [label="dungeon::cli::parse to CrawlArgs"]; run_crawl [label="run_crawl"]; run_diff [label="run_crawl_diff"]; update_run [label="update::run_update_with"]; text [label="text output"];
  args -> crawl -> parse; args -> update -> update_run; args -> help -> text; args -> repl;
  backend [label="--backend, -b default mock"]; serve [label="--serve"]; port [label="--port n default 0"]; out [label="--out path"]; budget [label="--budget n default DEFAULT_BUDGET"]; playwright [label="--playwright"]; mock_size [label="--mock-size presets or COUNTxPER seed"]; snapshot [label="--snapshot path"]; diff [label="--diff old new"];
  parse -> backend -> run_crawl; parse -> serve -> run_crawl; parse -> port -> run_crawl; parse -> out -> run_crawl; parse -> budget -> run_crawl; parse -> playwright -> run_crawl; parse -> mock_size -> run_crawl; parse -> snapshot -> run_crawl; parse -> diff -> run_diff;
  runner [label="ProcessAzRunner or mock_gen FakeAzRunner"]; map [label="dungeon::map::build_cancellable"]; render [label="render_html or playwright"]; html_file [label="optional --out HTML"]; snap_file [label="optional --snapshot DungeonMap JSON"]; server [label="optional server::serve"]; read_snap [label="read snapshot files"]; diff_maps [label="diff_maps"]; report [label="render_report"];
  run_crawl -> runner -> map; map -> render -> html_file; map -> snap_file; map -> server; run_diff -> read_snap -> diff_maps -> report;
  bind [label="bind 127.0.0.1:port; default port 0"]; middleware [label="auth middleware none; loopback only; read-only"]; handle [label="handle_connection"]; route [label="route map method path"]; resp [label="RouteResponse"];
  server -> bind -> middleware -> handle -> route;
  index [label="GET / to HTML"]; rooms [label="GET /api/v1/rooms to RoomSummary JSON"]; room [label="GET /api/v1/rooms/id to RoomDetail JSON"]; resource [label="GET /api/v1/resources/id to ResourceDetail JSON"]; e405 [label="non GET to 405"]; e404 [label="unknown to 404"]; scrub [label="secrets::scrub"];
  route -> index -> resp; route -> rooms -> scrub -> resp; route -> room -> scrub; route -> resource -> scrub; route -> e405 -> resp; route -> e404 -> resp;
  parser [label="parser::parse"]; repl -> parser;
  parser -> look [label="look,l"]; look [label="World::look"]; parser -> examine [label="examine,x,inspect,show target"]; examine [label="World::examine"]; parser -> go [label="go,move,walk,directions"]; go [label="World::go"]; parser -> take [label="take,get,grab,acquire target"]; take [label="confirm then World::take"]; parser -> drop [label="drop,delete,release,rm target"]; drop [label="confirm then World::drop_item"]; parser -> lock [label="lock,secure target"]; lock [label="World::lock"]; parser -> unlock [label="unlock,unward,unsecure target"]; unlock [label="World::unlock"]; parser -> resize [label="resize,rightsize,scale,downsize target"]; resize [label="World::resize"]; parser -> monitor [label="monitor,light"]; monitor [label="World::monitor"]; parser -> inv [label="inventory,i,inv"]; inv [label="World::inventory"]; parser -> score [label="score"]; score [label="World::score"]; parser -> ach [label="achievements,badges"]; ach [label="achievements_report"]; parser -> quest [label="quest,quests"]; quest [label="quests_report"]; parser -> cast [label="cast or deploy"]; cast [label="cast"]; parser -> learn [label="learn,discover,study group"]; learn [label="learn registry"]; parser -> caps [label="capabilities,caps,powers,spells"]; caps [label="capabilities_report"]; parser -> friction [label="friction,note,gripe text"]; friction [label="GraphMemory::record_friction"]; parser -> recall [label="recall,remember query"]; recall [label="recall_report"]; parser -> memory [label="memory,mem,recollect"]; memory [label="GraphMemory::summary"]; parser -> helpcmd [label="help,?,h"]; helpcmd [label="help_text"]; parser -> version [label="version,ver"]; version [label="version banner"]; parser -> quit [label="quit,q,exit"]; quit [label="print score and quit"]; parser -> unknown [label="unknown"]; unknown [label="IntentResolver and unresolved friction"];
  oit_args [label="azork-oit args"]; dry [label="--dry-run"]; oit_report [label="--report path default docs/oit-friction-report.md"]; oit_main [label="OIT main"]; preflight [label="preflight live only"]; guard [label="guardrails"]; catalog [label="catalog"]; drive [label="drive_azork"]; detect [label="detect_friction"]; md [label="ReportData::to_markdown"]; write [label="write report"];
  oit_args -> dry -> oit_main; oit_args -> oit_report -> oit_main; oit_main -> preflight [label="non-dry-run only"]; oit_main -> guard; oit_main -> catalog -> drive -> detect -> md -> write;
}
