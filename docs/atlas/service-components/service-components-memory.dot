  memory_mod -> gmem; gmem -> mem_node; gmem -> mem_edge; mem_node -> kind; gmem -> weights; gmem -> remember; remember -> secrets; record_intent -> remember; record_friction -> remember; remember_room -> remember; remember_resource -> remember; remember_resource -> add_edge; remember_cap -> remember; gmem -> recall; gmem -> summary; gmem -> save; gmem -> load; save -> path; load -> path; main_loop -> record_intent; main_loop -> remember_room; main_loop -> remember_resource; main_loop -> record_friction; main_loop -> recall; main_loop -> save;
